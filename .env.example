# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_IDS=123456789,987654321

# Timezone Settings
TIMEZONE=Asia/Kolkata

# Database Settings
DB_PATH=attendance.db

# Google Sheets Configuration
# You can specify the Spreadsheet ID directly (recommended)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
# Or the Spreadsheet Name
GOOGLE_SPREADSHEET_NAME=Employee Attendance Systems

# Google Credentials (JSON raw string or file path)
# Option A: Path to the service_account.json file
GOOGLE_CREDS_FILE=service_account.json
# Option B: Raw JSON content of service_account.json (preferred for Heroku/Render)
GOOGLE_CREDS_JSON=

# Dashboard Auth (REQUIRED if hosting the dashboard publicly)
# The dashboard has no other access control and exposes employee PII, fines,
# and admin actions. If DASHBOARD_PASSWORD is left blank, auth is disabled
# (fine for local development only). Set both when deploying.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# Dashboard server (used only when running dashboard/app.py directly, e.g.
# local dev; in production run it via gunicorn instead, see README)
PORT=5000
FLASK_DEBUG=false
